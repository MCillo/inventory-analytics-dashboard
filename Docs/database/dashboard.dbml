//Table Relationships

// Category 1 - M SubCategory 1 - M Product
// Vendor 1 - M Product
// SalesRep 1 - M Product
// Product 1 - M InventorySnapshot
// Product 1 - M SalesHistory
// ImportBatch 1 - M SalesHistory
// ImportBatch 1 - M InventorySnapshot
// Role 1 - M AppUser
// Vendor 1 - M SalesRep
// OrderScenario 1 - M OrderScenarioItem
// Product 1 - M OrderScenarioItem
// Product 1 - M ProductFinancial
// ImportBatch 1 - M ProductFinancial


// Using Sqlite3 which stores boolean values as either a
// 1 = True / Yes
// 0 = False / No 


Table Category {
    CategoryId int [pk, increment, not null]
    CategoryName varchar(50) [unique]
}

Table SubCategory {
    SubCategoryId int [pk, increment, not null]
    SubCategoryName varchar(50)

    CategoryId int [not null, ref: > Category.CategoryId]
}

Table Vendor {
    VendorId int [pk, increment, not null]
    VendorName varchar(150) [unique]
}

Table  SalesRep {
    SalesRepId int [pk, increment, not null]
    ContactFirstName varchar(50)
    ContactLastName varchar(50)
    ContactPhone varchar(25)
    ContactEmail varchar(255)
    SalesRepPosition varchar(50)

    VendorId int [not null, ref: > Vendor.VendorId]
}

Table Product {
    ProductId int [pk, increment, not null]
    SKU int [unique]   // This would be our in house SKU that we use, it can be null for New products that haven't been added to our system yet 
    ProductName varchar(255)
    Size varchar(50) //1.75L, 750ml, 30pk
    CasePack int // number of bottles or units per case 
    IsSeasonal boolean
    IsDiscontinued boolean
    IsInPOS boolean
    DealLevel int // This is a numeric representation of the deal level, with 1 being the lowest and 5 being the highest. 

    SubCategoryId int [ref: > SubCategory.SubCategoryId]
    VendorId int [ref: > Vendor.VendorId]
    SalesRepId int [ref: > SalesRep.SalesRepId]
}

Table InventorySnapshot {
    InventorySnapshotId int [pk, increment, not null]
    QuantityOnHand int 
    SnapshotDate datetime // The date and time when the inventory snapshot was taken 

    ImportBatchId int [not null, ref: > ImportBatch.ImportBatchId]
    ProductId int [not null, ref: > Product.ProductId]
    
}

Table SalesHistory {
    SalesHistoryId int [pk, increment, not null]
    UnitsSold int
    PeriodStartDate datetime
    PeriodEndDate datetime

    ImportBatchId int [not null, ref: > ImportBatch.ImportBatchId]
    ProductId int [not null, ref: > Product.ProductId]
    
}
 
Table OrderScenario {
  OrderScenarioId int [pk, increment]
  ScenarioName varchar(100)
  ScenarioDate datetime
  DealDescription varchar(150)
  TotalDealCases int
  Notes varchar(255)

  VendorId int [ref: > Vendor.VendorId]
  SalesRepId int [ref: > SalesRep.SalesRepId]
  UserId int [ref: > AppUser.UserId]
}

Table OrderScenarioItem {
  OrderScenarioItemId int [pk, increment]

  OrderScenarioId int [ref: > OrderScenario.OrderScenarioId]
  ProductId int [ref: > Product.ProductId]

  TempProductName varchar(150)
  TempSize varchar(50)
  TempNotes varchar(255)

  ProposedCases int
  ProposedBottles int
}

Table ImportBatch {
    ImportBatchId int [pk, increment, not null]
    ImportDate datetime // The date and time when the import was performed
    ReportDate datetime // The Date the import file was created
    FileName varchar(255)
    ImportType varchar(50)
    Status varchar(50)

}

Table Role {
    RoleId int [pk, increment, not null] 
    RoleName varchar(50) [unique]
    
}

Table AppUser {
    UserId int [pk, increment]  
    UserFirstName varchar(50)
    UserLastName varchar(50)
    UserEmail varchar(255)

    RoleId int [not null, ref: > Role.RoleId]

    PasswordHash varchar(255) // to be added in a later version when I implement authentication
    MfaEnabled boolean // to be added in a later version when I implement authentication
    IsActive boolean // to be added in a later version when I implement authentication

}


Table ProductFinancial {
    ProductFinancialId int [pk, increment]
    EffectiveDate datetime

    ProductId int [ref: > Product.ProductId, not null]
    ImportBatchId int [ref: > ImportBatch.ImportBatchId, not null]

    RetailPrice decimal
    CostPrice decimal
    MarginPercent decimal
    MarginDollars decimal
}